# Dockerfile for creating Jetson sysroot for OpenCV cross-compilation
# Downloads and extracts L4T packages without installing (avoids hardware checks)

# Define build arguments
ARG UBUNTU_VERSION=22.04
ARG JETPACK_VERSION=r36.3        # r36.3 for JP6 or r35.4.1 for JP5
ARG BOARD_TYPE=t234              # t234 for JP6/Orin or t194 for JP5/Xavier
ARG L4T_VERSION=36.3.0           # 36.3.0 for JP6 or 35.4.1 for JP5

# Use an ARM64 Ubuntu base image
FROM arm64v8/ubuntu:${UBUNTU_VERSION}

# Create and initialize the log file
RUN touch /build.log

# Avoid interactive prompts during package installation
ENV DEBIAN_FRONTEND=noninteractive

ARG JETPACK_VERSION
ARG BOARD_TYPE
ARG L4T_VERSION

# Install basic tools
RUN apt-get update && apt-get install -y \
    wget \
    ca-certificates \
    apt-utils \
    gnupg 2>&1 | tee -a /build.log

# Add NVIDIA repositories for Jetson
RUN echo "deb https://repo.download.nvidia.com/jetson/common ${JETPACK_VERSION} main" > /etc/apt/sources.list.d/nvidia-l4t-apt-source.list && \
    echo "deb https://repo.download.nvidia.com/jetson/${BOARD_TYPE} ${JETPACK_VERSION} main" >> /etc/apt/sources.list.d/nvidia-l4t-apt-source.list && \
    wget -qO - https://repo.download.nvidia.com/jetson/jetson-ota-public.asc | apt-key add - 2>&1 | tee -a /build.log

# Update package lists
RUN apt-get update 2>&1 | tee -a /build.log

# Download L4T packages without installing them
# This avoids the hardware detection checks in preinst scripts
RUN mkdir -p /tmp/l4t-packages /sysroot && cd /tmp/l4t-packages && \
    apt-get download \
    nvidia-l4t-core \
    nvidia-l4t-cuda \
    nvidia-l4t-cudnn \
    nvidia-l4t-tensorrt \
    nvidia-l4t-multimedia \
    nvidia-l4t-camera 2>&1 | tee -a /build.log || \
    echo "Some L4T packages may not be available" | tee -a /build.log

# Extract the downloaded packages into /sysroot
# Do NOT use dpkg -i (which would run preinst scripts and fail)
RUN cd /tmp/l4t-packages && \
    for deb in *.deb; do \
        echo "Extracting $deb to /sysroot..." | tee -a /build.log; \
        dpkg-deb -x "$deb" /sysroot; \
    done 2>&1 | tee -a /build.log

# Copy extracted L4T files to root for easier packaging
RUN if [ -d /sysroot/usr ]; then \
        cp -a /sysroot/usr/* /usr/ 2>&1 | tee -a /build.log; \
    fi && \
    if [ -d /sysroot/lib ]; then \
        cp -a /sysroot/lib/* /lib/ 2>&1 | tee -a /build.log; \
    fi && \
    if [ -d /sysroot/etc ]; then \
        cp -a /sysroot/etc/* /etc/ 2>&1 | tee -a /build.log; \
    fi

# Fix common CUDA symlinks (extracted .debs may have broken symlinks)
RUN echo "Fixing CUDA symlinks..." | tee -a /build.log && \
    cd /usr/local/cuda/lib64 2>/dev/null && \
    for lib in libcudart.so libcublas.so libcufft.so libcurand.so libcusparse.so; do \
        if [ -f ${lib}.*.* ] && [ ! -f ${lib} ]; then \
            base=$(ls -1 ${lib}.*.* | head -1); \
            ln -sf $base ${lib} 2>&1 | tee -a /build.log; \
            echo "Created symlink: ${lib} -> $base" | tee -a /build.log; \
        fi; \
    done || echo "CUDA lib64 directory not found, skipping symlink fixes" | tee -a /build.log

# ================================
# Base build tools
# ================================
RUN apt-get update && apt-get install -y \
    ca-certificates \
    wget \
    git \
    pkg-config \
    python3 \
    build-essential \
    bison \
    gperf \
    make \
    ninja-build \
    cmake \
    libclang-dev \
    software-properties-common \
    && rm -rf /var/lib/apt/lists/*

# ================================
# Graphics + Qt build dependencies
# (Mesa / X11 / EGL � generic)
# ================================
RUN apt-get update && apt-get install -y \
    # Core X11 / XCB
    libx11-dev \
    libx11-xcb-dev \
    libxcb1-dev \
    libxcb-util-dev \
    libxcb-icccm4-dev \
    libxcb-image0-dev \
    libxcb-keysyms1-dev \
    libxcb-randr0-dev \
    libxcb-render0-dev \
    libxcb-render-util0-dev \
    libxcb-shape0-dev \
    libxcb-shm0-dev \
    libxcb-sync-dev \
    libxcb-xfixes0-dev \
    libxcb-xinerama0-dev \
    libxcb-xkb-dev \
    \
    # XKB
    libxkbcommon-dev \
    libxkbcommon-x11-dev \
    libxcb-cursor-dev \
    \
    # X11 extensions
    libxrender-dev \
    libxrandr-dev \
    libxi-dev \
    libxss-dev \
    libxtst-dev \
    \
    # GL / EGL (Mesa for build)
    libegl1-mesa-dev \
    libgles2-mesa-dev \
    libgbm-dev \
    libgl1-mesa-dev \
    mesa-common-dev \
    \
    # Misc Qt deps
    libfontconfig1-dev \
    libudev-dev \
    libpq-dev \
    pkg-config \
    && rm -rf /var/lib/apt/lists/*

# Install additional useful libraries
RUN apt-get install -y \
    libeigen3-dev \
    libgstreamer1.0-dev \
    libgstreamer-plugins-base1.0-dev \
    libdc1394-dev 2>&1 | tee -a /build.log || \
    echo "Some optional packages not available, continuing..." | tee -a /build.log

# Create symbolic link for CUDA if it exists
RUN if [ -d /usr/local/cuda-12.2 ]; then \
        ln -sf /usr/local/cuda-12.2 /usr/local/cuda; \
    elif [ -d /usr/local/cuda ]; then \
        echo "CUDA directory found at /usr/local/cuda"; \
    fi | tee -a /build.log

# List CUDA installation
RUN echo "=== CUDA Installation ===" | tee -a /build.log && \
    ls -la /usr/local/ | grep cuda | tee -a /build.log || \
    echo "No CUDA directory found in /usr/local" | tee -a /build.log

# List important library directories
RUN echo "=== Library directories ===" | tee -a /build.log && \
    ls -la /usr/lib/aarch64-linux-gnu/ | grep -E "(cuda|nv|tegra)" | tee -a /build.log || \
    echo "Checking complete" | tee -a /build.log

# Clean up
RUN apt-get clean && \
    rm -rf /var/lib/apt/lists/* && \
    rm -rf /tmp/l4t-packages

# ================================
# Generic ARM64 sysroot snapshot
# (NOT Jetson-specific)
# ================================
RUN tar czf /jetsonSysroot.tar.gz \
    /lib \
    /usr/include \
    /usr/lib \
    /usr/lib/aarch64-linux-gnu \
    /usr/lib/aarch64-linux-gnu/pkgconfig \
    /usr/share/pkgconfig

CMD ["/bin/bash"]
