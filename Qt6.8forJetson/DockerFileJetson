# ================================
# Base arguments (override at build)
# ================================
ARG UBUNTU_VERSION=20.04        # 20.04 (JP5-era) or 22.04 (JP6-era)

FROM arm64v8/ubuntu:${UBUNTU_VERSION}

ENV DEBIAN_FRONTEND=noninteractive

# ================================
# Base build tools
# ================================
RUN apt-get update && apt-get install -y \
    ca-certificates \
    wget \
    git \
    pkg-config \
    python3 \
    build-essential \
    bison \
    gperf \
    make \
    ninja-build \
    cmake \
    libclang-dev \
    software-properties-common \
    && rm -rf /var/lib/apt/lists/*

# ================================
# Graphics + Qt build dependencies
# (Mesa / X11 / EGL � generic)
# ================================
RUN apt-get update && apt-get install -y \
    # Core X11 / XCB
    libx11-dev \
    libx11-xcb-dev \
    libxcb1-dev \
    libxcb-util-dev \
    libxcb-icccm4-dev \
    libxcb-image0-dev \
    libxcb-keysyms1-dev \
    libxcb-randr0-dev \
    libxcb-render0-dev \
    libxcb-render-util0-dev \
    libxcb-shape0-dev \
    libxcb-shm0-dev \
    libxcb-sync-dev \
    libxcb-xfixes0-dev \
    libxcb-xinerama0-dev \
    libxcb-xkb-dev \
    \
    # XKB
    libxkbcommon-dev \
    libxkbcommon-x11-dev \
    libxcb-cursor-dev \
    \
    # X11 extensions
    libxrender-dev \
    libxrandr-dev \
    libxi-dev \
    libxss-dev \
    libxtst-dev \
    \
    # GL / EGL (Mesa for build)
    libegl1-mesa-dev \
    libgles2-mesa-dev \
    libgbm-dev \
    libgl1-mesa-dev \
    mesa-common-dev \
    \
    # Misc Qt deps
    libfontconfig1-dev \
    libudev-dev \
    libpq-dev \
    pkg-config \
    && rm -rf /var/lib/apt/lists/*

# ================================
# Generic ARM64 sysroot snapshot
# (NOT Jetson-specific)
# ================================
RUN tar czf /jetsonSysroot.tar.gz \
    /lib \
    /usr/include \
    /usr/lib \
    /usr/lib/aarch64-linux-gnu \
    /usr/lib/aarch64-linux-gnu/pkgconfig \
    /usr/share/pkgconfig

CMD ["/bin/bash"]
